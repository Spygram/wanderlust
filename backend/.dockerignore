# Dependencies (reinstalled via npm ci inside the image)
node_modules

# Env files with secrets — don't want these baked into image layers
.env
.env.sample
.env.docker

# Local data / seed files not needed at runtime (already mounted via volume in compose)
data

# Git
.git
.gitignore

# Docker files (no need to copy these into build context)
Dockerfile
Dockerfile_0
docker-compose.yml

# Editor/OS cruft
.vscode
.idea
*.log
.DS_Store

# Tests — optional, exclude if you don't run tests inside the image
tests

# Misc configs not needed at runtime
.eslintrc.json
.eslintignore
.prettierrc
.prettierignore
.babelrc
vercel.json
